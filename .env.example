# Copy this to .env.local and fill in all the values
# Never commit .env.local — it's in .gitignore

# -----------------------------------------------
# Microsoft OAuth (Azure App Registration)
# -----------------------------------------------
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
# for Conestoga students, tenant ID is usually "common" or your school's tenant
MICROSOFT_TENANT_ID=common

# -----------------------------------------------
# Session
# -----------------------------------------------
# random 32+ char string — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------
# Supabase
# -----------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------
# Smart features API (optional — app still works without this)
# -----------------------------------------------
ANTHROPIC_API_KEY=your-key-here

# -----------------------------------------------
# D2L Brightspace
# -----------------------------------------------
BRIGHTSPACE_API_BASE_URL=https://conestoga.desire2learn.com

# -----------------------------------------------
# Encryption
# -----------------------------------------------
# used to encrypt Brightspace tokens before storing in DB
# generate: openssl rand -hex 32
ENCRYPTION_KEY=your-32-char-hex-key

# -----------------------------------------------
# Web Push Notifications (optional)
# -----------------------------------------------
# generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=you@example.com
